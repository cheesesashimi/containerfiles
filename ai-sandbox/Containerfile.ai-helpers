# The contents of this file represent a more fully-featured version of the
# Containerfile found at https://github.com/openshift-eng/ai-helperss. The major differences are:
# 1. It is based upon my standard workspace toolbox image.
# 2. It clones that repo as opposed to copying it from local storage and it
# 3. I've consolidated the individual layers to be more space-efficient.

ARG FEDORA_VERSION=44

FROM quay.io/zzlotnik/toolbox:tools-fetcher AS tools-fetcher

FROM quay.io/fedora/fedora-toolbox:${FEDORA_VERSION} AS final

COPY install-plugins.py plugins.yaml /opt/plugins
COPY --from=tools-fetcher /usr/local/bin /usr/local/bin

RUN --mount=type=cache,target=/var/cache/dnf,z \
	--mount=type=cache,target=/var/cache/libdnf5,z \
  git clone --depth=1 https://github.com/openshift-eng/ai-helpers.git /opt/ai-helpers && \
  dnf install -y \
    buildah \
    cargo \
    curl \
    delve \
    fd-find \
    fuse-overlayfs \
    fzf \
    gh \
    git \
    git-delta \
    golang \
    golang-x-tools-goimports \
    golang-x-tools-gopls \
    hadolint \
    jq \
    nodejs \
    podman \
    python3 \
    python3-devel \
    python3-lsp-server \
    python3-pip \
    ripgrep \
    rust-analyzer \
    shellcheck \
    skopeo \
    tmux \
    yq && \
  pip3 install --no-cache-dir \
    pytest \
    requests \
    pyyaml && \
  npm install -g dmux && \
  useradd -m -u 1000 -g 0 -s /bin/bash claude && \
  echo -e "claude:1001:65536" > /etc/subuid && \
  echo -e "claude:1001:65536" > /etc/subgid && \
  chmod u+s /usr/bin/newuidmap /usr/bin/newgidmap && \
  chown -R claude:root /opt/plugins && \
  chmod +x /opt/plugins/install-plugins.py && \
  chown -R claude:root /opt/ai-helpers && \
  mkdir -p /home/claude/.claude/plugins && \
  chown -R claude:root /home/claude && \
  mkdir -p /home/claude/.config && \
  chown -R claude:root /home/claude/.config && \
  mkdir -p /home/claude/.local/share/containers && \
  chown -R claude:root /home/claude/.local && \
  mkdir -p /workspace && chown -R claude:root /workspace && \
  find / -type d -name '__pycache__' | xargs rm -rf && \
  find / -type d -name 'node_modules/.cache' | xargs rm -rf && \
  rm -rf /tmp/node-compile-cache

VOLUME /var/lib/containers
VOLUME /home/claude/.local/share/containers

RUN mkdir -p /var/lib/shared/overlay-images \
  /var/lib/shared/overlay-layers \
  /var/lib/shared/vfs-images \
  /var/lib/shared/vfs-layers && \
  touch /var/lib/shared/overlay-images/images.lock && \
  touch /var/lib/shared/overlay-layers/layers.lock && \
  touch /var/lib/shared/vfs-images/images.lock && \
  touch /var/lib/shared/vfs-layers/layers.lock

USER claude

WORKDIR /opt/plugins

# Install Claude Code CLI using the official installation script
RUN mkdir -p /home/claude/.config/containers && \
  printf '[storage]\ndriver = "overlay"\n\n[storage.options.overlay]\nmount_program = "/usr/bin/fuse-overlayfs"\n' \
    > /home/claude/.config/containers/storage.conf && \
  printf '[containers]\nnetns = "host"\n\n[engine]\ncgroup_manager = "cgroupfs"\nevents_logger = "file"\n' \
    > /home/claude/.config/containers/containers.conf && \
  curl -fsSL https://claude.ai/install.sh | bash && \
  curl -fsSL https://opencode.ai/install | bash && \
  /opt/plugins/install-plugins.py && \
  chmod -R g+rwx /home/claude && \
  chmod -R g+rwx /opt/ai-helpers && \
  chmod -R g+rwx /workspace && \
  rm -rf /tmp/node-compile-cache && \
  rm -rf /home/claude/.claude/backups && \
  find / -type d -name '__pycache__' | xargs rm -rf && \
  find / -type d -name 'node_modules/.cache' | xargs rm -rf && \
  rm -rf /tmp/node-compile-cache

# Ensure ~/.local/bin is in PATH for the entrypoint
ENV PATH="/home/claude/.local/bin:${PATH}"
ENV CLAUDE_CONFIG_DIR="/home/claude/.claude"
ENV _CONTAINERS_USERNS_CONFIGURED=""
ENV BUILDAH_ISOLATION=rootless

WORKDIR /workspace

# Set Claude Code as the default command
ENTRYPOINT ["claude"]

# Default to showing help
CMD ["--help"]
